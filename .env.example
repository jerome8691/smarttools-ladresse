# Choix du moteur : auto, openai, gemini, groq, demo
AI_PROVIDER=auto

# OpenAI, si vous l'activez plus tard
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Gemini, option gratuite/économique pour tester
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Groq, option gratuite/économique pour tester
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
